#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-only
# SPDX-FileCopyrightText: 2026 Steve Clarke <stephenlclarke@mac.com> - https://xyzzy.tools
#
# USAGE:
#   fixdecoder [fixdecoder args...]
#
# Runs a locally built Go fixdecoder application.
#
# Keep this script in `scripts/` inside a source checkout after `make build`.
#
# Environment:
#   FIXDECODER_BIN  Use this executable instead of auto-discovering one.

set -euo pipefail

SELF_PATH="${BASH_SOURCE[0]:-$0}"
readonly SELF_PATH
SCRIPT_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
readonly SCRIPT_DIR
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly REPO_DIR
BIN_DIR="${REPO_DIR}/bin"
readonly BIN_DIR

# Write an error and exit.
function error() {
  printf '%s\n' "$*" >&2
  exit 1
}

# Find a generated fixdecoder executable in the repository bin directory.
function find_generated_binary() {
  [[ -d "$BIN_DIR" ]] || return 0
  find "$BIN_DIR" \
    -maxdepth 1 \
    -type f \
    -perm -111 \
    -name 'fixdecoder*' \
    -print 2>/dev/null | sort | tail -n 1
}

# Resolve the Go binary to execute, preferring the standard build name.
function resolve_binary() {
  local candidate

  if [[ -n "${FIXDECODER_BIN:-}" ]]; then
    [[ -x "$FIXDECODER_BIN" ]] || error "FIXDECODER_BIN is not executable: ${FIXDECODER_BIN}"
    printf '%s\n' "$FIXDECODER_BIN"
    return
  fi

  candidate="${BIN_DIR}/fixdecoder"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return
  fi

  candidate=$(find_generated_binary)
  if [[ -n "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return
  fi

  error "fixdecoder binary not found; set FIXDECODER_BIN or run make build"
}

# Run the application, replacing this wrapper process.
function main() {
  local binary

  binary=$(resolve_binary)
  exec "$binary" "$@"
}

main "$@"
